{
  "name": "@the-cascade-protocol/cli",
  "version": "0.5.2",
  "description": "Cascade Protocol CLI - Validate, convert, and manage health data",
  "bin": {
    "cascade": "dist/index.js"
  },
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "copy-shapes": "rm -rf dist/shapes && mkdir -p dist/shapes && cp -r src/shapes/* dist/shapes/",
    "copy-data": "mkdir -p dist/data && (cp src/data/rxnorm-names.json dist/data/rxnorm-names.json 2>/dev/null || echo '{}' > dist/data/rxnorm-names.json)",
    "build": "tsc && npm run copy-shapes && npm run copy-data",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cascade-protocol",
    "health-data",
    "rdf",
    "turtle",
    "shacl",
    "fhir",
    "cli"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-cascade-protocol/cli.git"
  },
  "homepage": "https://cascadeprotocol.org",
  "bugs": {
    "url": "https://github.com/the-cascade-protocol/cli/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "DOCKER.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@the-cascade-protocol/agent": "^1.1.0",
    "adm-zip": "^0.5.16",
    "commander": "^13.0.0",
    "fast-xml-parser": "^5.5.9",
    "n3": "^1.17.0",
    "rdf-validate-shacl": "^0.5.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/n3": "^1.16.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
