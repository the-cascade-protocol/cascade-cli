{
  "name": "@cascade-protocol/cli",
  "version": "0.1.0",
  "description": "Cascade Protocol CLI - Validate, convert, and manage health data",
  "bin": {
    "cascade": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "copy-shapes": "cp -r src/shapes dist/shapes",
    "build": "tsc && npm run copy-shapes",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cascade-protocol",
    "health-data",
    "rdf",
    "turtle",
    "shacl",
    "fhir",
    "cli"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "commander": "^12.0.0",
    "jsonld": "^8.3.0",
    "n3": "^1.17.0",
    "rdf-validate-shacl": "^0.5.0"
  },
  "devDependencies": {
    "@types/jsonld": "^1.5.0",
    "@types/n3": "^1.16.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
