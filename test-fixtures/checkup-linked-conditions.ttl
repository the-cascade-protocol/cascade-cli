# Trimmed synthetic Cascade Checkup intake-form export, for M1 literal lifting.
#
# Mirrors the shape CheckupSerializer.swift actually writes (verified 2026-07-20):
#   - condition subjects are `<#condition-{uuid}>` fragments on the export doc
#   - `clinical:linkedConditionIds` packs the linked conditions' UUIDs into ONE
#     literal, COMMA-separated and lowercased (the clinical v1.10 deprecation
#     comment's "space-separated" wording is wrong; root backlog 4.12)
#   - supplements carry a free-text `checkup:reasonForUse`
#
# No real patient data: names and codes are textbook examples.
#
# What this fixture exercises:
#   - two resolvable linked-condition UUIDs (hypertension -> CKD, CKD -> hypertension)
#   - one dangling UUID that must be counted unresolved and NOT written
#   - a space-separated literal, to prove both delimiters parse
#   - a supplement reasonForUse that name-matches a condition (lifted)
#   - a supplement reasonForUse that matches nothing (unmatched, literal retained)

@prefix cascade: <https://ns.cascadeprotocol.org/core/v1#> .
@prefix clinical: <https://ns.cascadeprotocol.org/clinical/v1#> .
@prefix checkup: <https://ns.cascadeprotocol.org/checkup/v1#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/checkup/condition-11111111-1111-4111-8111-111111111111>
    a checkup:ConditionSummary ;
    checkup:conditionName "Essential hypertension" ;
    checkup:conditionStatus "active" ;
    clinical:snomedCode "59621000" ;
    cascade:dataProvenance cascade:PatientReported ;
    cascade:schemaVersion "1.3" ;
    clinical:linkedConditionIds "22222222-2222-4222-8222-222222222222,99999999-9999-4999-8999-999999999999" .

<https://example.org/checkup/condition-22222222-2222-4222-8222-222222222222>
    a checkup:ConditionSummary ;
    checkup:conditionName "Chronic kidney disease" ;
    checkup:conditionStatus "active" ;
    clinical:snomedCode "709044004" ;
    cascade:dataProvenance cascade:PatientReported ;
    cascade:schemaVersion "1.3" ;
    clinical:linkedConditionIds "11111111-1111-4111-8111-111111111111" .

<https://example.org/checkup/condition-33333333-3333-4333-8333-333333333333>
    a checkup:ConditionSummary ;
    checkup:conditionName "Seasonal allergic rhinitis" ;
    checkup:conditionStatus "active" ;
    cascade:dataProvenance cascade:PatientReported ;
    cascade:schemaVersion "1.3" ;
    clinical:linkedConditionIds "11111111-1111-4111-8111-111111111111 22222222-2222-4222-8222-222222222222" .

<https://example.org/checkup/supplement-44444444-4444-4444-8444-444444444444>
    a checkup:SupplementSummary ;
    checkup:supplementName "Cholecalciferol" ;
    checkup:reasonForUse "Chronic kidney disease" ;
    cascade:dataProvenance cascade:PatientReported ;
    cascade:schemaVersion "1.3" .

<https://example.org/checkup/supplement-55555555-5555-4555-8555-555555555555>
    a checkup:SupplementSummary ;
    checkup:supplementName "Magnesium glycinate" ;
    checkup:reasonForUse "General wellness" ;
    cascade:dataProvenance cascade:PatientReported ;
    cascade:schemaVersion "1.3" .
